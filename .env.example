# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=your_db_user
DATABASE_PASSWORD=your_db_password
DATABASE_NAME=kedgr
DATABASE_URL=postgresql://postgres:1234@localhost:5432/kedgr

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Google Generative AI Configuration
GOOGLE_GENAI_API_KEY=your_google_api_key_here

# AI Model Configuration
# Recommended: gemini-1.5-flash (better quota limits than gemini-2.0-flash-lite)
# Options: gemini-1.5-flash, gemini-1.5-pro, gemini-2.0-flash, gemini-2.0-flash-lite
AI_MODEL=gemini-1.5-flash
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2048

# AI Feature Flags
ENABLE_AI_ANALYSIS=true
ENABLE_AI_RULESET_GENERATION=true
ENABLE_AI_SEARCH=true
ENABLE_AI_DOCS=true

# AI Cost Control & Rate Limiting
AI_MAX_REQUESTS_PER_MIN=15
AI_MAX_TOKENS_PER_REQUEST=8000
AI_RETRY_MAX_ATTEMPTS=3
AI_RETRY_INITIAL_DELAY_MS=1000

# Server Configuration
PORT=3000
NODE_ENV=development
SELF_PING_URL=http://localhost:3000/health

# Redis Configuration (BullMQ / Upstash)
# Use REDIS_URL or use REDIS_HOST & REDIS_PORT explicitly
# REDIS_URL=rediss://...
REDIS_USE_TLS=true

# GitHub App Configuration
GITHUB_APP_ID=your_github_app_id
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
# The secret you set in the GitHub App's webhook settings page
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret
# NOTE: No separate GITHUB_PRIVATE_KEY is needed.
# The GitHub App JWT is signed using the same RSA private key as the JWT auth system.
# Set JWT_PRIVATE_KEY (inline PEM) or JWT_PRIVATE_KEY_PATH (path to .pem file).

# Email Service (Resend)
# Toggle ENABLE_EMAILS=true to actually send emails. If false, emails are mocked in the console.
ENABLE_EMAILS=false
# Get your API key from resend.com
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=Kedgr Notifications <no-reply@yourdomain.com>

# Flutterwave Payment Gateway (supports NGN, USD, and other currencies)
# Get these from your Flutterwave dashboard: https://dashboard.flutterwave.com
FLW_SECRET_KEY=FLWSECK_TEST-your_secret_key_here
FLW_PUBLIC_KEY=FLWPUBK_TEST-your_public_key_here
# The Webhook Secret Hash you set in Flutterwave dashboard > Settings > Webhooks
FLW_WEBHOOK_SECRET_HASH=your_custom_hash_here
# URL Flutterwave redirects to after payment (?transaction_id=&tx_ref=&status=)
FLW_CALLBACK_URL=https://yourdomain.com/subscription/verify
# Optional: Branding logo shown on the Flutterwave checkout page
FLW_LOGO_URL=https://yourdomain.com/logo.png
