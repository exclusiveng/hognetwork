# HogNetwork Environment Configuration
PORT=3000
DATABASE_URL=postgresql://postgres:1234@localhost:5432/hognetwork
DB_SSL=false

# JWT Security
JWT_SECRET=super-secret-hog-network-key
JWT_EXPIRES_IN=7d

# Cloudinary Integration
CLOUDINARY_CLOUD_NAME=name-of-your-cloudinary-account
CLOUDINARY_API_KEY=api-key-from-cloudinary-dashboard
CLOUDINARY_API_SECRET=api-secret-from-cloudinary-dashboard

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

